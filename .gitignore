# These are some examples of commonly ignored file patterns.
# Learn more: https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Node
node_modules/

# Java / Maven
*.class
*.jar
target/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# Build / distribution
dist/
build/
*.spec

# IDEs
.idea/
.vscode/

# Unit test reports
TEST*.xml

# Logs and errors
*.log
error.txt
error_*.png

# Large files / drivers
msedgedriver.exe
*.exe
*.app
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini

# Dump SQL (muy grande, no subir a GitHub)
360.2020.10.24.sql

# Archivos empaquetados (muy grandes, redundantes con app/ y BD)
*.tgz

# App runtime / subidas (DERROTERO: tmp y upload)
# app/tmp/
# app/upload/

# Entorno y secretos
.env
.env.*
!.env.example

# Cursor / IDE
.cursor/

# Ignorar reporte360 como solicitó el usuario
reporte360/
